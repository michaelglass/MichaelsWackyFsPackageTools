<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Update="FSharp.Core" Version="10.1.201" />
    <PackageReference Include="xunit.v3" Version="3.2.2" />
    <PackageReference Include="xunit.v3.mtp-v2" Version="3.2.2" />
    <PackageReference Include="Unquote" Version="7.0.1" />
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" Version="18.5.2" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../../src/CoverageRatchet/CoverageRatchet.fsproj" />
    <ProjectReference Include="../Tests.Common/Tests.Common.fsproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="CoverageTestHelpers.fs" />
    <Compile Include="CoberturaTests.fs" />
    <Compile Include="ThresholdsTests.fs" />
    <Compile Include="RatchetTests.fs" />
    <Compile Include="ProgramTests.fs" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="xunit.runner.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
